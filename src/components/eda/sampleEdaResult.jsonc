    },

    // one of: general|regression|classification|clustering|time_series
    "task_type": "general",
    // resolved target column (optional)
    "target_column": "Price",
    // resolved time column if any (optional)
    "time_column": "ListedDate",

    // ── dataset summary ──
    "row_count": 2059,
    "column_count": 20,

    // ── task_metrics (keys vary by task_type) ──
