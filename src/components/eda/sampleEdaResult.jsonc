        "id": "insight_1", "category": "distribution", "severity": "warning",
        "title": "Highly Skewed Price Distribution",
        "description": "Price is heavily right-skewed (skewness 4.97, kurtosis 40.3). Extreme luxury listings pull the mean far above the median.",
        "affected_columns": ["Price"],
        "recommendation": "Apply log transform or Yeo-Johnson before modeling to normalise the target distribution."
      },
      {
        "id": "insight_2", "category": "correlation", "severity": "warning",
        "title": "Multicollinearity Among Vehicle Dimensions",
        "description": "Length, Width, and Fuel Tank Capacity are strongly intercorrelated (r > 0.81), introducing redundancy.",
        "affected_columns": ["Length", "Width", "Fuel Tank Capacity"],
        "recommendation": "Use PCA on vehicle dimension features or drop the least informative one."
      }
    ],

