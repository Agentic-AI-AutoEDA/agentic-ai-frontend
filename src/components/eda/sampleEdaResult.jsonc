    "insights": [
      {
        "id": "insight_1",
        "category": "distribution",
        "severity": "warning",
        "title": "Highly Skewed Price Distribution",
        "description": "Price distribution is heavily right-skewed with extreme high-value outliers.",
        "affected_columns": [ "Price" ],
        "recommendation": "Apply log transform or cap extremes before modeling."
      },
      {
        "id": "insight_2",
        "category": "correlation",
        "severity": "warning",
        "title": "Multicollinearity Among Dimensions",
        "description": "Length, Width, and Fuel Tank Capacity show high pairwise correlations.",
        "affected_columns": [ "Length", "Width", "Fuel Tank Capacity" ],
        "recommendation": "Consider dimensionality reduction or feature selection."
